    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" >
    <Shell id="shell">
        <App id="app">
            <pages>
                <Page id="page" title="{i18n>title}" >
                <content>
                        <l:ResponsiveFlowLayout id="mainFlowLayout">
                            <core:Fragment fragmentName="pcc.custfiles.zcustomerfilesv2.fragment.main.FilesVBox" type="XML" />
                        </l:ResponsiveFlowLayout>
                </content>
                </Page>
            </pages>
        </App>
    </Shell>
</mvc:View>
